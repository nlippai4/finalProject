# ================= RAW DATA ================== #

# FASTQ / sequencing data
*.fastq
*.fastq.gz
*.fq
*.fq.gz

# BAM / alignment files
*.bam
*.bai
*.sam
*.bai

# Mapped BAMs
possorted_genome_bam.bam

# Raw data: keep directory placeholder only
rawdata/*
!rawdata/.gitkeep


# ================= REFERENCE ================= #

# Large reference transcriptome/genome files
reference/*
!reference/.gitkeep

refdata*


# ============= CELLRANGER OUTPUTS ============= #

# Ignore full CellRanger outputs
results/01_cellranger/
results/*/01_cellranger/
*_cellranger/
outs/


# ============= GENOTYPE DEMULTIPLEXING =============== #

# VCFs
vcf/filtered/
vcf/merge/
vcf/original/
vcf/subset/clone1/*.vcf*
vcf/subset/clone2/*.vcf*
vcf/subset/clone3/*.vcf*
vcf/subset/clone4/*.vcf*


# cellSNP outputs
results/02_cellsnp/
results/02_cellsnp_pooled/


# vireo outputs
results/03_vireo/


# ============= LARGE INTERMEDIATES ========== #

# Seurat / AnnData / large objects
*.rds
*.RDS
*.h5
*.h5ad
*.loom

# Integrated objects
integrated_*.rds

# Sparse matrices
matrix.mtx
barcodes.tsv
features.tsv


# ================= RESULTS =================== #

# Auto-generated figures
*.png
*.pdf
*.svg
*.jpeg
*.jpg

# QC reports
*_qc.html
*_report.html

# Logs
*.log
*.out
*.err
slurm-*.out


# ============== SCRATCH / HPC =============== #

scratch/
tmp/
temp/
*.tmp
