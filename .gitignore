# ================= RAW DATA ================== #

# FASTQ / sequencing data
*.fastq
*.fastq.gz
*.fq
*.fq.gz

# BAM / alignment files
*.bam
*.bai
*.sam
*.bai

# Mapped BAMs
possorted_genome_bam.bam

# Raw data: keep directory placeholder only
rawdata/*
!rawdata/.gitkeep


# ================= REFERENCE ================= #

# Large reference transcriptome/genome files
reference/*
!reference/.gitkeep

refdata*


# ============= CELLRANGER OUTPUTS ============= #

# Ignore full CellRanger outputs
results/01_cellranger/
results/*/01_cellranger/
*_cellranger/
outs/


# ============= GENOTYPE DEMULTIPLEXING =============== #

# VCFs: keep directory structure, ignore VCF contents
vcf/filtered/*
!vcf/filtered/.gitkeep

vcf/merge/*
!vcf/merge/.gitkeep

vcf/original/*
!vcf/original/.gitkeep

vcf/subset/*
!vcf/subset/.gitkeep
!vcf/subset/clone1/
!vcf/subset/clone2/
!vcf/subset/clone3/
!vcf/subset/clone4/

vcf/subset/clone1/*
!vcf/subset/clone1/.gitkeep

vcf/subset/clone2/*
!vcf/subset/clone2/.gitkeep

vcf/subset/clone3/*
!vcf/subset/clone3/.gitkeep

vcf/subset/clone4/*
!vcf/subset/clone4/.gitkeep


# cellSNP outputs
results/02_cellsnp/
results/02_cellsnp_pooled/


# vireo outputs
results/03_vireo/


# ============= LARGE INTERMEDIATES ========== #

# Seurat / AnnData / large objects
*.rds
*.RDS
*.h5
*.h5ad
*.loom

# Integrated objects
integrated_*.rds

# Sparse matrices
matrix.mtx
barcodes.tsv
features.tsv


# ================= RESULTS =================== #

# Auto-generated figures
*.png
*.pdf
*.svg
*.jpeg
*.jpg

# QC reports
*_qc.html
*_report.html

# Logs
*.log
*.out
*.err
slurm-*.out


# ============== SCRATCH / HPC =============== #

scratch/
tmp/
temp/
*.tmp
